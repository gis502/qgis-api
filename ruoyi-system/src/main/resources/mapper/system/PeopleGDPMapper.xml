<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.slave.PeopleGDPMapper">

    <!-- 查询椭圆范围内的人口数和GDP数量 -->
    <select id="findInsideCircle" resultType="com.ruoyi.system.domain.entity.base.PeopleGDP">
        SELECT *
        FROM xian_gdp_people
        WHERE ST_Within(geom, #{Geometry})
    </select>

</mapper>
